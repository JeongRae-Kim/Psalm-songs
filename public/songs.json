  "songs": [
    {
      "id": "psalm-6",
      "psalmNumber": 6,
      "verseRange": "1-10절",
      "title": "여호와여 나를 책망하지 마시고",
      "tuneName": "PLAYFORD",
      "meter": "8 8 8 8",
      "composer": "John Playford (1623-1693)",
      "arranger": "김준범",
      "arrangedYear": 2026,
      "scripture": "시편 6편 1-10절",
      "verses": [
        {
          "number": 1,
          "text": "여호와여 주의 노로 날 책망하지 마시며\n주님의 진노로 나를 징계하지 마옵소서"
        },
        {
          "number": 2,
          "text": "주여 내가 쇠약하며 나의 뼈가 떨리오니\n나를 긍휼히 여기사 주여 나를 고치소서"
        },
        {
          "number": 3,
          "text": "나의 영혼 떨리오니 주여 언제까지니까\n주의 인자하심으로 나를 구원해주소서"
        },
        {
          "number": 4,
          "text": "사망 중에 어찌 주를 기억할 수 있사오며\n음부에서 누가 주께 감사할 수 있으리까"
        },
        {
          "number": 5,
          "text": "내가 밤마다 눈물로 나의 침상을 적시며\n나의 대적을 인하여 내가 쇠하였나이다"
        },
        {
          "number": 6,
          "text": "나의 간구 나의 기도 주께서 들으셨으니\n나의 모든 원수들이 떨며 물러가리로다"
        }
      ],
      "sheetImage": "/sheets/psalm-006.png",
      "sheetPdf": "/sheets/psalm-006.pdf",
      "midiFile": "/midi/psalm-006.mid",
      "mxlFile": "/mxl/psalm-006.mxl",
      "bpm": 110,
      "introMeasures": 4,
      "hasAmen": false
    },
    {
      "id": "psalm-23",
      "psalmNumber": 23,
      "verseRange": "1-6절",
      "title": "여호와는 나의 목자시니",
      "tuneName": "SKODSBORG",
      "meter": "11 10 11 10",
      "composer": "A. P. Berggren",
      "arranger": "김준범",
      "arrangedYear": 2026,
      "scripture": "시편 23편 1-6절",
      "verses": [
        {
          "number": 1,
          "text": "여호와는 내 선한 목자시니\n나 부족함이 없으리로다\n푸른 초장과 쉴만한 물가로\n그가 나를 인도하시도다"
        },
        {
          "number": 2,
          "text": "내 영혼을 소생시켜 주시고\n의의 길로 인도하시나니\n사망 음침한 골짜기 지나도\n해를 두려워하지 않으리"
        },
        {
          "number": 3,
          "text": "주님께서 나와 함께 하시며\n주의 지팡이와 막대기로\n나를 안위하며 보호하시니\n나 두려워 아니하나이다"
        },
        {
          "number": 4,
          "text": "주님께서 원수의 목전에서\n내게 상을 베풀어 주시고\n내 머리에 기름을 부으시니\n내 잔이 차고 넘치나이다"
        },
        {
          "number": 5,
          "text": "내 평생에 주님의 선하심과\n인자하심 나를 따르리니\n내가 정녕 주 여호와의 집에\n영원히 거하리로다 아멘"
        }
      ],
      "sheetImage": "/sheets/psalm-023.png",
      "sheetPdf": "/sheets/psalm-023.pdf",
      "midiFile": "/midi/psalm-023.mid",
      "mxlFile": "/mxl/psalm-023.mxl",
      "bpm": 110,
      "introMeasures": 4,
      "hasAmen": false
    },
    {
      "id": "psalm-40",
      "psalmNumber": 40,
      "verseRange": "1-5절",
      "title": "여호와 여 내가 주를 간절히 기다렸더니",
      "tuneName": "DUNSTAN",
      "meter": "8 8 8 6 8 6",
      "composer": "Joseph Barnby (1892)",
      "arranger": "김준범",
      "arrangedYear": 2026,
      "scripture": "시편 40편 1-5절",
      "verses": [
        {
          "number": 1,
          "text": "여호와여 내가 주를 간절히 기다렸더니\n주님께서 나의 간구를 물리치지 않고\n그의 귀를 기울이사 응답하셨도다"
        },
        {
          "number": 2,
          "text": "기가 막힐 웅덩이와 수렁에서 건지시고\n나의 발을 반석 위에 굳게 세우시고\n나의 걸음을 견고하게 붙드셨나이다"
        },
        {
          "number": 3,
          "text": "새 노래로 하나님께 찬송하게 하셨으니\n많은 사람들이 보고 두려워하면서\n여호와를 경외하며 주를 의지하리라"
        },
        {
          "number": 4,
          "text": "여호와를 의지하고 교만히 행치 않으며\n거짓을 행치 않는 자도 다 복이 있나니\n복있도다 복있도다 주를 의지하리라"
        },
        {
          "number": 5,
          "text": "주께서 행하신 기적 어찌 그리 많은지요\n우리를 향한 생각도 심히 많으시니\n내가 다 말할 수 없고 셀 수 없나이다"
        }
      ],
      "sheetImage": "/sheets/psalm-040.png",
      "sheetPdf": "/sheets/psalm-040.pdf",
      "midiFile": "/midi/psalm-040.mid",
      "mxlFile": "/mxl/psalm-040.mxl",
      "bpm": 105,
      "introMeasures": 4,
      "hasAmen": false
    },
    {
      "id": "psalm-42-1",
      "psalmNumber": 42,
      "verseRange": "1-5절",
      "title": "사슴이 시냇물 찾아 헤매갈 급함과 같이",
      "tuneName": "O WALY WALY",
      "meter": "8 8 8 8",
      "composer": "Appalachian folk melody",
      "arranger": "김준범",
      "arrangedYear": 2026,
      "scripture": "시편 42편 1-5절",
      "verses": [
        {
          "number": 1,
          "text": "사슴이 시냇물 찾아 헤매\n갈급함과 같이\n내 영혼이 하나님을 찾기에\n갈급합니도다"
        },
        {
          "number": 2,
          "text": "내 영혼이 살아계신 하나님을\n갈망하니\n나 어느 때에 나아가서\n하나님 얼굴 뵈올꼬"
        },
        {
          "number": 3,
          "text": "사람들이 네 하나님\n어디 있느냐 말하니\n나의 눈물이 주야로\n내 음식 되었나이다"
        },
        {
          "number": 4,
          "text": "내가 성일을 지키는 무리들과\n동행하며\n성전으로 인도하며\n늘 찬송하였나이다"
        },
        {
          "number": 5,
          "text": "여호와여 내가 이제\n이전 일을 기억하고\n지난날을 생각하며\n나의 마음 상합니도다"
        },
        {
          "number": 6,
          "text": "내 영혼아 어찌하여\n내 속에서 낙망하며\n어찌 불안해하는가\n네 하나님을 바라라"
        },
        {
          "number": 7,
          "text": "찬양하라 내 영혼아\n네 하나님을 바라라\n그 도우심을 인하여\n오히려 찬송하리라"
        }
      ],
      "sheetImage": "/sheets/psalm-042-1.png",
      "sheetPdf": "/sheets/psalm-042-1.pdf",
      "midiFile": "/midi/psalm-042-1.mid",
      "mxlFile": "/mxl/psalm-042-1.mxl",
      "bpm": 115,
      "introMeasures": 4,
      "hasAmen": false
    },
    {
      "id": "psalm-42-6",
      "psalmNumber": 42,
      "verseRange": "6-11절",
      "title": "여호와 여 나의 영혼 내 속에서 낙망하여",
      "tuneName": "BACA",
      "meter": "8 8 8 8 8",
      "composer": "William B. Bradbury (1816-1868)",
      "arranger": "김준범",
      "arrangedYear": 2026,
      "scripture": "시편 42편 6-11절",
      "verses": [
        {
          "number": 1,
          "text": "여호와여 나의 영혼 내 속에서 낙망하여\n요단 땅과 헤르몬과 미살 산의 언덕에서\n주를 기억하나이다"
        },
        {
          "number": 2,
          "text": "주의 파도와 물결이 나를 엄습하였어도\n주의 인자를 인하여 밤에도 나 찬송하며\n주께 기도하리이다"
        },
        {
          "number": 3,
          "text": "나의 반석 여호와여 나를 잊으셨나이까\n내가 어찌 원수 인해 슬프게 다니나이까\n주여 날 기억하소서"
        },
        {
          "number": 4,
          "text": "나의 대적 말하기를 네 하나님 어디 있느뇨\n날 찌르는 칼과 같이 항상 나를 비방하니\n주여 언제까지니이까"
        },
        {
          "number": 5,
          "text": "어찌하여 낙망하며 어찌 불안해하는가\n네 하나님을 바라라 나는 나를 도우시는\n하나님 찬송하리라"
        }
      ],
      "sheetImage": "/sheets/psalm-042-6.png",
      "sheetPdf": "/sheets/psalm-042-6.pdf",
      "midiFile": "/midi/psalm-042-6.mid",
      "mxlFile": "/mxl/psalm-042-6.mxl",
      "bpm": 115,
      "introMeasures": 4,
      "hasAmen": false
    },
    {
      "id": "psalm-84",
      "psalmNumber": 84,
      "verseRange": "9-12절",
      "title": "우리의 방패를 보옵소서",
      "tuneName": "ANGELS' SONG",
      "meter": "변박 (1/4, 4/4, 3/4)",
      "composer": "A.H.Mann",
      "arranger": "서창원",
      "arrangedYear": 2001,
      "scripture": "시편 84편 9-12절",
      "verses": [
        {
          "number": 1,
          "text": "우리의 방패이신 여호와 하나님\n주 기름 부으신 자의 얼굴을\n살펴보옵소서\n주님의 궁정에서 한 날\n있는 것이 천 날 다른 곳보다\n복이 있나이다"
        },
        {
          "number": 2,
          "text": "악인의 장막에서 장수함보다도\n주님의 궁정에서 문지기하옴이\n무엇과도 바꿀 수 없이 좋사오니\n복 있는 자 누구랴\n나의 주 하나님"
        }
      ],
      "sheetImage": "/sheets/psalm-084.png",
      "sheetPdf": "/sheets/psalm-084.pdf",
      "midiFile": "/midi/psalm-084.mid",
      "mxlFile": "/mxl/psalm-084.mxl",
      "bpm": 120,
      "introMeasures": 4,
      "hasAmen": false
    },
    {
      "id": "psalm-90",
      "psalmNumber": 90,
      "verseRange": "1-12절",
      "title": "주 여호와 여 주는 대대로 우리 거처가 되셨나니",
      "tuneName": "VITA",
      "meter": "10 9 11 10 9",
      "composer": "A. P. Berggren (1801-1880)",
      "arranger": "김준범",
      "arrangedYear": 2026,
      "scripture": "시편 90편 1-12절",
      "verses": [
        {
          "number": 1,
          "text": "주 여호와여 주는 대대로 우리 거처가 되셨나니\n땅과 세계를 조성하시기 전\n주는 영원부터 영원까지 우리 하나님이시라"
        },
        {
          "number": 2,
          "text": "주의 목전에 지난 천년이 밤의 한 경점과 같으니\n저희는 잠깐 자는 것 같으며\n아침에 돋는 풀과 같으니 다 티끌로 돌아가리라"
        },
        {
          "number": 3,
          "text": "아침에 돋아 꽃을 피우나 저녁엔 모두 마르리니\n우리는 주의 노에 소멸되며\n주의 분노에 놀라나이다 주 앞에 누가 서리이까"
        },
        {
          "number": 4,
          "text": "주께서 우리 은밀한 죄를 주 얼굴 앞에 두셨으니\n우리의 평생 우리 모든 날\n주의 분노 중에 지나가며 일식간에 다하나이다"
        },
        {
          "number": 5,
          "text": "우리의 연수 칠십이 되며 강건하면 팔십이라도\n연수의 자랑 수고와 슬픔뿐\n화살과 같이 신속히 가니 우리 인생 가나이다"
        },
        {
          "number": 6,
          "text": "누가 주님의 진노의 능력 그 두려움 다 알리이까\n우리의 날수 헤아려 알도록\n주여 우리를 가르치소서 지혜의 마음을 주소서"
        }
      ],
      "sheetImage": "/sheets/psalm-090.png",
      "sheetPdf": "/sheets/psalm-090.pdf",
      "midiFile": "/midi/psalm-090.mid",
      "mxlFile": "/mxl/psalm-090.mxl",
      "bpm": 110,
      "introMeasures": 4,
      "hasAmen": false
    },
    {
      "id": "psalm-119-41",
      "psalmNumber": 119,
      "verseRange": "41-48절",
      "title": "여호와여 주의 인자하심을 내게 베푸사",
      "tuneName": "SANDS",
      "meter": "88 88 88 8",
      "composer": "William J. Kirkpatrick (1838-1921)",
      "arranger": "김준범",
      "arrangedYear": 2026,
      "scripture": "시편 119편 41-48절",
      "verses": [
        {
          "number": 1,
          "text": "여호와의 말씀대로 주의 자비를 베푸사\n주의 구원을 나에게 임하게 하여 주소서\n날 비방하는 자에게 대답할 말을 주소서\n주님만 의지합니다"
        },
        {
          "number": 2,
          "text": "주의 진리의 말씀을 항상 내 입에 두소서\n주여 내가 주의 규례 간절히 바라나이다\n내가 항상 주의 율법사모하고 의지하여\n영영히 지키리이다"
        },
        {
          "number": 3,
          "text": "여호와여 내가 주의 법도를 구하였으니\n나의 걸음을 붙드사 자유하게 하옵소서\n내가 왕들 앞에서서 주의 교훈 말할 때에\n수치 당하지 않게 마소서"
        },
        {
          "number": 4,
          "text": "여호와의 계명들을 내가 즐거워하며\n주의 계명 사랑하여 내 손을 높이 듭니다\n여호와여 내 영혼이 주의 율례의 말씀을\n항상 묵상하리이다"
        }
      ],
      "sheetImage": "/sheets/psalm-119-41.png",
      "sheetPdf": "/sheets/psalm-119-41.pdf",
      "midiFile": "/midi/psalm-119-41.mid",
      "mxlFile": "/mxl/psalm-119-41.mxl",
      "bpm": 70,
      "introMeasures": 4,
      "hasAmen": false
    },
    {
      "id": "psalm-119-65",
      "psalmNumber": 119,
      "verseRange": "65-72절",
      "title": "주여 주는 선하사 선을 행하시오니",
      "tuneName": "ETERNITY",
      "meter": "7 7 7 5",
      "composer": "Samuel S. Wesley (1810-1876)",
      "arranger": "김준범",
      "arrangedYear": 2026,
      "scripture": "시편 119편 65-72절",
      "verses": [
        {
          "number": 1,
          "text": "주여 주는 주의 종 선대하셨나이다\n주의 명철로 나를 가르치소서"
        },
        {
          "number": 2,
          "text": "고난당하기 전에는 그릇 행하였나니\n이제는 주의 말씀을 지키나이다"
        },
        {
          "number": 3,
          "text": "여호와는 선하사 선을 행하시오니\n주의 율례로 나를 가르치소서"
        },
        {
          "number": 4,
          "text": "주여 교만한 자가 나를 치려했으나\n나는 주의 법도를 지키리이다"
        },
        {
          "number": 5,
          "text": "주여 저희 마음은 어리석고 둔하오나\n주님의 법을 즐거워하나이다"
        },
        {
          "number": 6,
          "text": "내가 고난당한 것이 나에게 유익이라\n이로 인하여 주의 율례 배웠나이다"
        },
        {
          "number": 7,
          "text": "주의 입의 말씀과 주의 법이 내게는\n천천금은보다 더 귀하나이다"
        }
      ],
      "sheetImage": "/sheets/psalm-119-65.png",
      "sheetPdf": "/sheets/psalm-119-65.pdf",
      "midiFile": "/midi/psalm-119-65.mid",
      "mxlFile": "/mxl/psalm-119-65.mxl",
      "bpm": 110,
      "introMeasures": 4,
      "hasAmen": false
    },
    {
      "id": "psalm-119-73",
      "psalmNumber": 119,
      "verseRange": "73-80절",
      "title": "주가 나를 만드시고 세우셨사오니",
      "tuneName": "GOSHEN",
      "meter": "8 6 8 6 D",
      "composer": "W. Gawler's Hymns and Psalms (1789)",
      "arranger": "김준범",
      "arrangedYear": 2026,
      "scripture": "시편 119편 73-80절",
      "verses": [
        {
          "number": 1,
          "text": "주가 나를 만드시고 세우셨사오니\n주여 나로 주의 계명 깨닫게 하소서\n주를 경외하는 자가 기뻐하는 것은\n내가 주님의 말씀에 소망을 둠이라"
        },
        {
          "number": 2,
          "text": "여호와여 주의 판단 의로우시며\n주님의 성실하심도 내가 아옵나이다\n여호와여 구하오니 주의 말씀대로\n주의 인자하심으로 날 위로하소서"
        },
        {
          "number": 3,
          "text": "주님의 긍휼로 나를 살게 하옵소서\n주의 법은 나의 기쁨 내 즐거움이라\n교만한 자가 무고히 나를 괴롭히나\n나는 여호와의 법도 묵상하리이다"
        },
        {
          "number": 4,
          "text": "주를 경외하는 자로 내게 돌이키사\n저희로 주의 증거를 알게 하옵소서\n나로 주님의 율례에 완전하게 하사\n나로 수치를 당하지 않게 하옵소서"
        }
      ],
