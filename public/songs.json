  "songs": [
    {
      "id": "psalm-6",
      "psalmNumber": 6,
      "verseRange": "1-10절",
      "title": "여호와여 나를 책망하지 마시고",
      "tuneName": "PLAYFORD",
      "meter": "8 8 8 8",
      "composer": "John Playford (1623-1693)",
      "arranger": "김준범",
      "arrangedYear": 2026,
      "scripture": "시편 6편 1-10절",
      "verses": [
        {
          "number": 1,
          "text": "여호와여 나를 책망하지 마시고\n주의 진노로 나를 징계하지 마시며\n주님의 긍휼히 여기사\n나를 고쳐주소서"
        },
        {
          "number": 2,
          "text": "나의 뼈가 떨리오니\n주여 나를 긍휼히 여기사\n나를 구원하여 주소서\n나의 영혼이 심히 떨리나이다"
        },
        {
          "number": 3,
          "text": "주의 인자하심으로\n나를 구하여 주소서\n사망 중에서 주를 기억할 수 있으며\n음부에서 주께 감사할 수 있으리이까"
        },
        {
          "number": 4,
          "text": "내가 밤마다 눈물로\n나의 침상을 적시며\n내 자리를 물러가게 하였나이다"
        },
        {
          "number": 5,
          "text": "사람들의 압제에서\n나의 눈이 쇠하며\n나의 모든 대적을 인하여\n나의 간구를 물리치소서"
        },
        {
          "number": 6,
          "text": "내 원수들이 떨며\n물러가며 쇠하리로다\n여호와여 나의 기도를 들으시고\n나의 간구를 해주소서"
        }
      ],
      "sheetImage": "/sheets/psalm-006.png",
      "sheetPdf": "/sheets/psalm-006.pdf",
      "midiFile": "/midi/psalm-006.mid",
      "mxlFile": "/mxl/psalm-006.mxl",
      "bpm": 110
    },
    {
      "id": "psalm-23",
      "psalmNumber": 23,
      "verseRange": "1-6절",
      "title": "여호와는 나의 목자시니",
      "tuneName": "SKODSBORG",
      "meter": "11 10 11 10",
      "composer": "A. P. Berggren",
      "arranger": "김준범",
      "arrangedYear": 2026,
      "scripture": "시편 23편 1-6절",
      "verses": [
        {
          "number": 1,
          "text": "여호와는 나의 목자시니 내게 부족함이\n없으리로다 그 푸른 초장기에\n나를 누이시며 쉴 만한 물가로\n인도하시니 나의 영혼을 소생시키시고"
        },
        {
          "number": 2,
          "text": "내 평생에 주와 함께하시며\n주의 길로 인도하시니\n나 두려워 아니하리로다\n내 잔이 넘치나이다"
        },
        {
          "number": 3,
          "text": "사망의 음침한 골짜기로 다닐지라도\n해를 두려워하지 않음은\n주의 지팡이와 막대기가\n나를 안위하심이니이다"
        },
        {
          "number": 4,
          "text": "주께서 내 원수의 목전에서\n내게 상을 베푸시고\n기름을 내 머리에 부으셨으니\n내 잔이 넘치나이다"
        },
        {
          "number": 5,
          "text": "내 평생에 선하심과 인자하심이\n나를 따르리니\n내가 여호와의 집에 영원히\n살리로다 아멘"
        }
      ],
      "sheetImage": "/sheets/psalm-023.png",
      "sheetPdf": "/sheets/psalm-023.pdf",
      "midiFile": "/midi/psalm-023.mid",
      "mxlFile": "/mxl/psalm-023.mxl",
      "bpm": 110
    },
    {
      "id": "psalm-40",
      "psalmNumber": 40,
      "verseRange": "1-5절",
      "title": "여호와 여 내가 주를 간절히 기다렸더니",
      "tuneName": "DUNSTAN",
      "meter": "8 8 8 6 8 6",
      "composer": "Joseph Barnby (1892)",
      "arranger": "김준범",
      "arrangedYear": 2026,
      "scripture": "시편 40편 1-5절",
      "verses": [
        {
          "number": 1,
          "text": "여호와 여 내가 주를 간절히 기다렸더니\n주님께서 나의 간구 물리치지 않고\n그의 귀를 기울이사 응답하셨도다"
        },
        {
          "number": 2,
          "text": "기가 막힐 웅덩이와 수렁에서 건지시고\n나의 발을 반석위에 굳게 세우셨으니\n나의 걸음 견고하게 붙으셨나이다"
        },
        {
          "number": 3,
          "text": "새 노래로 하나님께 찬송하게 하셨으니\n많은 사람들이 보고 두려워하면서\n여호와를 경외하며 주를 의지하리"
        },
        {
          "number": 4,
          "text": "여호와를 의지하고 교만히 행치 않으며\n거짓을 행치 않는 자 다 복이 있나니\n복 있도다 복 있도다 주를 의지하라"
        },
        {
          "number": 5,
          "text": "여호와의 행하신 일 어찌 그리 많은지요\n우리를 향한 생각도 심히 많으시니\n내가 다 말할 수 없고 셀 수 없나이다"
        }
      ],
      "sheetImage": "/sheets/psalm-040.png",
      "sheetPdf": "/sheets/psalm-040.pdf",
      "midiFile": "/midi/psalm-040.mid",
      "mxlFile": "/mxl/psalm-040.mxl",
      "bpm": 105
    },
    {
      "id": "psalm-42-1",
      "psalmNumber": 42,
      "verseRange": "1-5절",
      "title": "사슴이 시냇물 찾아 헤매갈 급함과 같이",
      "tuneName": "O WALY WALY",
      "meter": "8 8 8 8",
      "composer": "Appalachian folk melody",
      "arranger": "김준범",
      "arrangedYear": 2026,
      "scripture": "시편 42편 1-5절",
      "verses": [
        {
          "number": 1,
          "text": "사슴이 시냇물 찾아 헤매갈 급함과 같이\n내 영혼이 하나님을 찾기에 갈급합니다"
        },
        {
          "number": 2,
          "text": "내 영혼이 살아계신 하나님을 갈망하니\n나 어느 때에 나아가 하나님 얼굴 뵈올꼬"
        },
        {
          "number": 3,
          "text": "사람들이 네 하나님 어디에 있느냐 하니\n나의 눈물이 주야로 내 음식 되었나이다"
        },
        {
          "number": 4,
          "text": "내가 성일을 지키는 무리들과 동행하며\n성전으로 인도하며 기뻐 찬송했나이다"
        },
        {
          "number": 5,
          "text": "여호와 여 내가 이제 이전 일을 기억하고\n지난 날을 생각하며 내 마음 상하나이다"
        },
        {
          "number": 6,
          "text": "내 영혼아 어찌하여 내 속에서 낙망하며\n어찌 불안 해하는가 네 하나님을 바라라"
        },
        {
          "number": 7,
          "text": "찬양하라 내 영혼아 네 하나님을 바라라\n그 도우심을 인하여 오히려 찬송하리라"
        }
      ],
      "sheetImage": "/sheets/psalm-042-1.png",
      "sheetPdf": "/sheets/psalm-042-1.pdf",
      "midiFile": "/midi/psalm-042-1.mid",
      "mxlFile": "/mxl/psalm-042-1.mxl",
      "bpm": 115
    },
    {
      "id": "psalm-42-6",
      "psalmNumber": 42,
      "verseRange": "6-11절",
      "title": "여호와 여 나의 영혼 내 속에서 낙망하여",
      "tuneName": "BACA",
      "meter": "8 8 8 8 8",
      "composer": "William B. Bradbury (1816-1868)",
      "arranger": "김준범",
      "arrangedYear": 2026,
      "scripture": "시편 42편 6-11절",
      "verses": [
        {
          "number": 1,
          "text": "여호와 여 나의 영혼 내 속에서 낙망하여\n요단 땅과 헤르몬과 미살산의 언덕에 서\n주를 기억하나이다"
        },
        {
          "number": 2,
          "text": "주의 파도와 물결이 나를 엄습 하였어도\n낮에는 주의 인자와 밤에는 찬송이 있어\n주께 기도하리이다"
        },
        {
          "number": 3,
          "text": "나의 반석 여호와여 나를 잊으셨나이까\n내가 어찌 원수인 해 슬프게 다니나이까\n주여 날 기억하소서"
        },
        {
          "number": 4,
          "text": "나의 대적 말하기를 네 하나님 어딨느뇨\n날 찌르는 칼과 같이 항상 나를 비방하니\n주여 언제까지니이까"
        },
        {
          "number": 5,
          "text": "어찌하여 낙망하며 어찌 불안 해하는가\n네 하나님을 바라라 나는 나를 도우시는\n하나님 찬송하리라"
        }
      ],
      "sheetImage": "/sheets/psalm-042-6.png",
      "sheetPdf": "/sheets/psalm-042-6.pdf",
      "midiFile": "/midi/psalm-042-6.mid",
      "mxlFile": "/mxl/psalm-042-6.mxl",
      "bpm": 115
    },
    {
      "id": "psalm-84",
      "psalmNumber": 84,
      "verseRange": "9-12절",
      "title": "우리의 방패를 보옵소서",
      "tuneName": "ANGELS' SONG",
      "meter": "변박 (1/4, 4/4, 3/4)",
      "composer": "A.H.Mann",
      "arranger": "서창원",
      "arrangedYear": 2001,
      "scripture": "시편 84편 9-12절",
      "verses": [
        {
          "number": 1,
          "text": "우리의 방패이신 여호와 하나님\n주 기름 부으신 자의 얼굴을\n살펴보옵소서\n주님의 궁정에서 한 날\n있는 것이 천 날 다른 곳보다\n복이 있나이다"
        },
        {
          "number": 2,
          "text": "악인의 장막에서 장수함보다도\n주님의 궁정에서 문지기하옴이\n무엇과도 바꿀 수 없이 좋사오니\n복 있는 자 누구랴\n나의 주 하나님"
        }
      ],
      "sheetImage": "/sheets/psalm-084.png",
      "sheetPdf": "/sheets/psalm-084.pdf",
      "midiFile": "/midi/psalm-084.mid",
      "mxlFile": "/mxl/psalm-084.mxl",
      "bpm": 120
    },
    {
      "id": "psalm-90",
      "psalmNumber": 90,
      "verseRange": "1-12절",
      "title": "주 여호와 여 주는 대대로 우리 거처가 되셨나니",
      "tuneName": "VITA",
      "meter": "10 9 11 10 9",
      "composer": "A. P. Berggren (1801-1880)",
      "arranger": "김준범",
      "arrangedYear": 2026,
      "scripture": "시편 90편 1-12절",
      "verses": [
        {
          "number": 1,
          "text": "주 여호와 여 주는 대대로 우리 거처가 되셨나니\n땅과 세계를 조성 하시기 전 주는 영원부터 영원까지\n우리의 하나님이시라"
        },
        {
          "number": 2,
          "text": "주의 목전에 지난 천년이 밤의 한 경점과 같으니\n저희는 잠깐 자는 것 같으며 아침에 돋는 풀과 같으니\n다 티끌로 돌아가지라"
        },
        {
          "number": 3,
          "text": "아침에 돋아 꽃을 피우나 저녁엔 모두 마르리니\n우리는 주의 노에 소멸되며 주의 분노에 놀라나이다\n다 식다가 하나이다"
        },
        {
          "number": 4,
          "text": "주께서 우리 은밀한 죄를 주 얼굴 앞에 두셨으니\n우리의 평생 우리의 모든 날 주의 분노 중에 지나가며\n일생간에 다 하나이다"
        },
        {
          "number": 5,
          "text": "우리의 연수 칠십 이되며 강건하면 팔십이라도\n연수의 자랑 수고와 슬픔뿐 화살 같이 신속히 가나니\n주 앞에 누가 서리이까"
        },
        {
          "number": 6,
          "text": "누가 주님의 진노의 능력 두려워할 대로 알리\n우리의 날 수 헤아려 알도록 주여 우리를 가르치소서\n지혜의 마음을 주소서"
        }
      ],
      "sheetImage": "/sheets/psalm-090.png",
      "sheetPdf": "/sheets/psalm-090.pdf",
      "midiFile": "/midi/psalm-090.mid",
      "mxlFile": "/mxl/psalm-090.mxl",
      "bpm": 110
    },
    {
      "id": "psalm-119-41",
      "psalmNumber": 119,
      "verseRange": "41-48절",
      "title": "여호와여 주의 인자하심을 내게 베푸사",
      "tuneName": "SANDS",
      "meter": "88 88 88 8",
      "composer": "William J. Kirkpatrick (1838-1921)",
      "arranger": "김준범",
      "arrangedYear": 2026,
      "scripture": "시편 119편 41-48절",
      "verses": [
        {
          "number": 1,
          "text": "여호와여 주의 인자하심을 내게 베푸사\n주의 구원을 주의 말씀대로 주소서\n날 비방하는 자에게 대답할 말을\n주소서 나 항상 주의 말씀을 바라나이다"
        },
        {
          "number": 2,
          "text": "주의 계명의 말씀을 내가 입에 두었사오니\n주의 규례를 항상 사모하여\n주의 걸음을 붙드사\n자유하게 하여주소서"
        },
        {
          "number": 3,
          "text": "여호와의 법도 내가 즐거워하오니\n주의 계명 사랑하여\n내 손을 높이 듭니다\n영원히 주의 율례를 묵상하리이다"
        },
        {
          "number": 4,
          "text": "여호와의 계명 내 거워하며\n주의 율례에 항상 즐겁게 순종하며\n주의 교훈 말씀을 영히 지키리이다"
        }
      ],
      "sheetImage": "/sheets/psalm-119-41.png",
      "sheetPdf": "/sheets/psalm-119-41.pdf",
      "midiFile": "/midi/psalm-119-41.mid",
      "mxlFile": "/mxl/psalm-119-41.mxl",
      "bpm": 70
    },
    {
      "id": "psalm-119-65",
      "psalmNumber": 119,
      "verseRange": "65-72절",
      "title": "주여 주는 선하사 선을 행하시오니",
      "tuneName": "ETERNITY",
      "meter": "7 7 7 5",
      "composer": "Samuel S. Wesley (1810-1876)",
      "arranger": "김준범",
      "arrangedYear": 2026,
      "scripture": "시편 119편 65-72절",
      "verses": [
        {
          "number": 1,
          "text": "주여 주는 선하사\n선을 행하시오니\n주의 선하심 나에게\n가르치소서"
        },
        {
          "number": 2,
          "text": "고난 당하기 전에\n내가 그릇 행하였으나\n이제는 주의 말씀을\n지키나이다"
        },
        {
          "number": 3,
          "text": "교만한 자가 나를\n거짓으로 모함하나\n나는 전심으로 주의 법을\n지키리이다"
        },
        {
          "number": 4,
          "text": "저희 마음은 살찌고\n둔하나 나는 주의\n율례를 즐거워합니다"
        },
        {
          "number": 5,
          "text": "주의 명철로 나를\n가르치소서\n천금은보다 주의 법이\n승하니이다"
        },
        {
          "number": 6,
          "text": "내가 고난 당한 것은\n나에게 유익하였으니\n주의 율례를 배웠나이다"
        },
        {
          "number": 7,
          "text": "주의 입의 법은\n나에게 천천 금은보다\n더 승하니이다"
        }
      ],
      "sheetImage": "/sheets/psalm-119-65.png",
      "sheetPdf": "/sheets/psalm-119-65.pdf",
      "midiFile": "/midi/psalm-119-65.mid",
      "mxlFile": "/mxl/psalm-119-65.mxl",
      "bpm": 110
    },
    {
      "id": "psalm-119-73",
      "psalmNumber": 119,
      "verseRange": "73-80절",
      "title": "주가 나를 만드시고 세우셨사오니",
      "tuneName": "GOSHEN",
      "meter": "8 6 8 6 D",
      "composer": "W. Gawler's Hymns and Psalms (1789)",
      "arranger": "김준범",
      "arrangedYear": 2026,
      "scripture": "시편 119편 73-80절",
      "verses": [
        {
          "number": 1,
          "text": "주가 나를 만드시고 세우셨사오니\n주의 계명 깨닫게 하옵소서\n주를 경외하는 자가 기뻐하는 것은\n내가 주의 말씀에 소망을 둠이라"
        },
        {
          "number": 2,
          "text": "여호와여 주의 판단이 의로우시고\n주의 성실하심으로 나를 고난당케 하신 줄\n나로 주님의 증거를 알게 하옵소서\n주의 인자하심으로 나를 위로하옵소서"
        },
        {
          "number": 3,
